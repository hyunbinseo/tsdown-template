{
	"name": "tsdown-starter",
	"version": "0.0.0",
	"description": "A starter for creating a TypeScript package.",
	"homepage": "https://github.com/user/repo#readme",
	"bugs": {
		"url": "https://github.com/user/repo/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/user/repo.git"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"exports": {
		".": "./dist/index.js",
		"./package.json": "./package.json"
	},
	"scripts": {
		"prepack": "tsdown",
		"version": "tsdown && git add package.json",
		"check": "tsc --noEmit",
		"fmt": "oxfmt",
		"fmt:check": "oxfmt --check",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix"
	},
	"devDependencies": {
		"@arethetypeswrong/core": "^0.18.2",
		"@types/node": "^24.12.2",
		"oxfmt": "^0.47.0",
		"oxlint": "^1.62.0",
		"publint": "^0.3.18",
		"tsdown": "^0.21.10",
		"typescript": "^6.0.3"
	}
}
